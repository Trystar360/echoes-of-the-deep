{
  "schemaVersion": 1,
  "id": "echoes",
  "version": "${version}",
  "name": "Octaves of the One",
  "description": "A tech mod themed on Walter Russell's cosmology: the two-way universe of rhythmic balanced interchange. Draw Light from the still centre of zero, wind it through the octaves by generation (compression) and radiation (expansion), and spend it across a wired and wireless grid.",
  "authors": ["Trystar360"],
  "contact": {
    "homepage": "https://github.com/Trystar360/echoes-of-the-deep",
    "sources": "https://github.com/Trystar360/echoes-of-the-deep",
    "issues": "https://github.com/Trystar360/echoes-of-the-deep/issues"
  },
  "license": "MIT",
  "icon": "assets/echoes/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["com.echoes.EchoesMod"],
    "client": ["com.echoes.client.EchoesClient"]
  },
  "mixins": [
    "echoes.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.0",
    "minecraft": ">=26.1",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {
    "trinkets": "*",
    "team_reborn_energy": "*"
  }
}
